{
  "client": {
    "allowed_origins": ["*"],
    "allow_anonymous_connect_without_token": true,
    "insecure": true
  },

  "http_api": {
    "key": "particles-demo-api-key",
    "external": true
  },

  "shared_poll": {
    "hmac_secret_key": "particles-demo-hmac-secret"
  },

  "proxies": [
    {
      "name": "backend",
      "endpoint": "http://localhost:3001/centrifugo/rpc",
      "timeout": "3s"
    }
  ],

  "rpc": {
    "without_namespace": {
      "proxy_enabled": true,
      "proxy_name": "backend"
    }
  },

  "channel": {
    "proxy": {
      "shared_poll_refresh": {
        "endpoint": "http://localhost:3001/centrifugo/refresh",
        "timeout": "5s"
      }
    },
    "namespaces": [
      {
        "name": "particles",
        "allow_subscribe_for_client": true
      },
      {
        "name": "tiles",
        "allow_subscribe_for_client": true,
        "subscription_type": "shared_poll",
        "shared_poll": {
          "refresh_interval": "10s",
          "refresh_batch_size": 256,
          "mode": "versioned",
          "max_keys_per_connection": 256,
          "publish_enabled": true
        }
      }
    ]
  }
}
